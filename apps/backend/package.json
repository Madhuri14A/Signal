{
  "name": "@signal/backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/db/seed.ts",
    "fetch:rss": "tsx src/workers/rssFetcher.ts",
    "embed": "tsx src/workers/embedder.ts",
    "cluster": "tsx src/workers/clustering.ts",
    "label": "tsx src/workers/labeler.ts",
    "schedule": "tsx src/scheduler.ts",
    "test:db": "npx tsx tests/db-connection.test.ts",
    "test:deps": "npx tsx tests/dependencies.test.ts",
    "test:env": "npx tsx tests/env-check.test.ts",
    "test:apis": "npx tsx tests/external-apis.test.ts",
    "test:all": "npm run test:env && npm run test:db && npm run test:deps && npm run test:apis"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.5",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.36.0",
    "pg": "^8.20.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.17.1",
    "typescript": "^5.5.4"
  }
}
